# Environment variables for development
# Copy this file to .env.local and fill in your Firebase credentials

NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# Resend Email Service (server-only — never expose to client)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@streamhub.app
APP_URL=http://localhost:3000

# Nuxt runtime config overrides (NUXT_ prefix maps automatically to runtimeConfig)
NUXT_RESEND_API_KEY=re_xxxxxxxxxxxx
NUXT_RESEND_FROM_EMAIL=noreply@streamhub.app
NUXT_APP_URL=http://localhost:3000

# Looker Studio API (Optional — if not set, Browse Reports feature is disabled)
# Use either GOOGLE_SERVICE_ACCOUNT_KEY (inline JSON) or GOOGLE_APPLICATION_CREDENTIALS (path to file)
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase Admin SDK (Server Auth Middleware)
# Required in production for API token verification.
# In development, if not set, middleware falls back to mock auth (uid from query param).
# Use GOOGLE_SERVICE_ACCOUNT_KEY above (shared) or set FIREBASE_SERVICE_ACCOUNT separately.
# FIREBASE_SERVICE_ACCOUNT=

# --- Production / CI/CD ---
# Set to 'true' to use Firestore instead of JSON mock in production
NUXT_PUBLIC_USE_FIRESTORE=true
NUXT_PUBLIC_USE_JSON_MOCK=false
