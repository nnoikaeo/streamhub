# Environment variables for development
# Copy this file to .env.local and fill in your Firebase credentials

NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# Resend Email Service (server-only — never expose to client)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@streamhub.app
APP_URL=http://localhost:3000

# Nuxt runtime config overrides (NUXT_ prefix maps automatically to runtimeConfig)
NUXT_RESEND_API_KEY=re_xxxxxxxxxxxx
NUXT_RESEND_FROM_EMAIL=noreply@streamhub.app
NUXT_APP_URL=http://localhost:3000
