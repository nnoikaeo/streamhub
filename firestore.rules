rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isModerator() {
      return isSignedIn() && userRole() == 'moderator';
    }

    function isAdminOrMod() {
      return isAdmin() || isModerator();
    }

    // Returns true if folderId is directly assigned to the current moderator
    function isAssignedFolder(folderId) {
      let f = get(/databases/$(database)/documents/folders/$(folderId)).data;
      return 'assignedModerators' in f && f.assignedModerators.hasAny([request.auth.uid]);
    }

    // Returns true if folderId is in the moderator's manageable tree
    // Checks: folder itself, its parent, or its grandparent (covers 3 levels deep)
    function isManagedFolder(folderId) {
      let f = get(/databases/$(database)/documents/folders/$(folderId)).data;
      return isAssignedFolder(folderId) ||
        (f.parentId != null && isAssignedFolder(f.parentId)) ||
        (f.parentId != null &&
          get(/databases/$(database)/documents/folders/$(f.parentId)).data.parentId != null &&
          isAssignedFolder(
            get(/databases/$(database)/documents/folders/$(f.parentId)).data.parentId
          ));
    }

    // ── users ─────────────────────────────────────────────────────────────────
    // Each user reads own doc (auth bootstrap on login).
    // Admins/mods read all users (permission management UI).
    // Only admins write.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdminOrMod());
      allow write: if isAdmin();
    }

    // ── folders ───────────────────────────────────────────────────────────────
    // All authenticated users read (client-side filters visibility per role).
    // Admins write any folder.
    // Moderators can create sub-folders (parentId != null) — app enforces manageable-tree check.
    // Moderators update: directly assigned folders OR folders whose parent/grandparent is assigned.
    // Moderators delete: only sub-folders they created (not directly-assigned root folders).
    match /folders/{folderId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() ||
        (isModerator() && request.resource.data.parentId != null);
      allow update: if isAdmin() ||
        (isModerator() && isManagedFolder(folderId));
      allow delete: if isAdmin() ||
        (isModerator() && resource.data.createdBy == request.auth.uid &&
          resource.data.parentId != null);
    }

    // ── dashboards ────────────────────────────────────────────────────────────
    // All authenticated users read (client-side filters by access.direct / company).
    // Admins write any dashboard.
    // Moderators create/update/delete dashboards in their managed folder tree.
    match /dashboards/{dashboardId} {
      allow read: if isSignedIn();
      allow create: if isAdminOrMod();
      allow update: if isAdmin() ||
        (isModerator() && isManagedFolder(resource.data.folderId));
      allow delete: if isAdmin() ||
        (isModerator() && isManagedFolder(resource.data.folderId));
    }

    // ── companies ─────────────────────────────────────────────────────────────
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── regions ───────────────────────────────────────────────────────────────
    match /regions/{regionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── groups ────────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── tags ──────────────────────────────────────────────────────────────────
    match /tags/{tagId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── invitations ───────────────────────────────────────────────────────────
    // Admins manage all invitations.
    // Invited person can read their own record (for accept page).
    match /invitations/{inviteId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.email == request.auth.token.email);
      allow write: if isAdmin();
    }

    // ── audit-log ─────────────────────────────────────────────────────────────
    // Admins read only. Writes are server-side via Admin SDK (always denied client-side).
    match /audit-log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
