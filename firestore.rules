rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isModerator() {
      return isSignedIn() && userRole() == 'moderator';
    }

    function isAdminOrMod() {
      return isAdmin() || isModerator();
    }

    // ── users ─────────────────────────────────────────────────────────────────
    // Each user reads own doc (auth bootstrap on login).
    // Admins/mods read all users (permission management UI).
    // Only admins write.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdminOrMod());
      allow write: if isAdmin();
    }

    // ── folders ───────────────────────────────────────────────────────────────
    // All authenticated users read (client-side filters visibility per role).
    // Admins write any folder.
    // Moderators update only folders where they are in assignedModerators.
    match /folders/{folderId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isModerator() && resource.data.assignedModerators.hasAny([request.auth.uid]));
      allow delete: if isAdmin();
    }

    // ── dashboards ────────────────────────────────────────────────────────────
    // All authenticated users read (client-side filters by access.direct / company).
    // Admins write any dashboard.
    // Moderators create/update dashboards in their assigned folders only.
    match /dashboards/{dashboardId} {
      allow read: if isSignedIn();
      allow create: if isAdminOrMod();
      allow update: if isAdmin() ||
        (isModerator() && get(/databases/$(database)/documents/folders/$(resource.data.folderId)).data.assignedModerators.hasAny([request.auth.uid]));
      allow delete: if isAdmin();
    }

    // ── companies ─────────────────────────────────────────────────────────────
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── regions ───────────────────────────────────────────────────────────────
    match /regions/{regionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── groups ────────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── tags ──────────────────────────────────────────────────────────────────
    match /tags/{tagId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── invitations ───────────────────────────────────────────────────────────
    // Admins manage all invitations.
    // Invited person can read their own record (for accept page).
    match /invitations/{inviteId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.email == request.auth.token.email);
      allow write: if isAdmin();
    }

    // ── audit-log ─────────────────────────────────────────────────────────────
    // Admins read only. Writes are server-side via Admin SDK (always denied client-side).
    match /audit-log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
